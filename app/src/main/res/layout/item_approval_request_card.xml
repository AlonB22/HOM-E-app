<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/Widget.HOME_App.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/stack_spacing">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/card_padding_large">

        <TextView
            android:id="@+id/text_approval_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:background="@drawable/bg_status_attention"
            android:paddingHorizontal="@dimen/chip_horizontal_padding"
            android:paddingVertical="@dimen/chip_vertical_padding"
            android:text="@string/label_status_awaiting_parent"
            android:textAppearance="@style/TextAppearance.HOME_App.Badge"
            android:textColor="@color/status_attention_text" />

        <TextView
            android:id="@+id/text_approval_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/stack_spacing"
            android:textAppearance="@style/TextAppearance.HOME_App.CardTitle" />

        <TextView
            android:id="@+id/text_approval_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/stack_spacing_small"
            android:textAppearance="@style/TextAppearance.HOME_App.Body" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/stack_spacing"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_approval_approve"
                style="@style/Widget.HOME_App.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/action_approve" />

            <Space
                android:layout_width="@dimen/stack_spacing_small"
                android:layout_height="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_approval_decline"
                style="@style/Widget.HOME_App.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/action_decline" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
