<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/screen_horizontal_padding"
        android:paddingTop="@dimen/section_spacing"
        android:paddingBottom="@dimen/section_spacing_large">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_child"
            android:paddingHorizontal="@dimen/badge_horizontal_padding"
            android:paddingVertical="@dimen/badge_vertical_padding"
            android:text="@string/label_child_view"
            android:textAppearance="@style/TextAppearance.HOME_App.Badge"
            android:textColor="@color/child_accent" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/stack_spacing"
            android:text="@string/child_home_summary"
            android:textAppearance="@style/TextAppearance.HOME_App.Body" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.HOME_App.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_spacing">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/child_metric_background"
                android:orientation="vertical"
                android:padding="@dimen/card_padding_large">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/child_home_points_label"
                    android:textAppearance="@style/TextAppearance.HOME_App.Supporting" />

                <TextView
                    android:id="@+id/text_points_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/stack_spacing_xsmall"
                    android:textAppearance="@style/TextAppearance.HOME_App.HeroTitle"
                    android:textColor="@color/child_accent" />

                <TextView
                    android:id="@+id/text_points_helper"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/stack_spacing_small"
                    android:textAppearance="@style/TextAppearance.HOME_App.Body" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/stack_spacing"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_open_my_chores"
                        style="@style/Widget.HOME_App.Button.Primary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/action_open_my_chores" />

                    <Space
                        android:layout_width="@dimen/stack_spacing_small"
                        android:layout_height="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_open_rewards_store"
                        style="@style/Widget.HOME_App.Button.Secondary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/action_open_rewards_store" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.HOME_App.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/stack_spacing">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding_large">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/child_home_priority_title"
                    android:textAppearance="@style/TextAppearance.HOME_App.CardTitle" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/stack_spacing_small"
                    android:text="@string/child_home_priority_body"
                    android:textAppearance="@style/TextAppearance.HOME_App.Supporting" />

                <LinearLayout
                    android:id="@+id/container_priority_chores"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/stack_spacing"
                    android:orientation="vertical" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.HOME_App.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/stack_spacing">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding_large">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/child_home_waiting_title"
                    android:textAppearance="@style/TextAppearance.HOME_App.CardTitle" />

                <TextView
                    android:id="@+id/text_waiting_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/stack_spacing_small"
                    android:textAppearance="@style/TextAppearance.HOME_App.ScreenTitle"
                    android:textColor="@color/child_accent" />

                <TextView
                    android:id="@+id/text_waiting_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/stack_spacing_xsmall"
                    android:textAppearance="@style/TextAppearance.HOME_App.Supporting" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_review_waiting"
                    style="@style/Widget.HOME_App.Button.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/stack_spacing"
                    android:text="@string/action_open_my_chores" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.HOME_App.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/stack_spacing">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding_large">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/child_home_rewards_preview_title"
                    android:textAppearance="@style/TextAppearance.HOME_App.CardTitle" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/stack_spacing_small"
                    android:text="@string/child_home_rewards_preview_body"
                    android:textAppearance="@style/TextAppearance.HOME_App.Supporting" />

                <LinearLayout
                    android:id="@+id/container_reward_preview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/stack_spacing"
                    android:orientation="vertical" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_open_profile"
            style="@style/Widget.HOME_App.Button.Text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_spacing"
            android:text="@string/action_open_profile" />
    </LinearLayout>
</ScrollView>
