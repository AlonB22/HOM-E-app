<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/screen_horizontal_padding"
        android:paddingTop="@dimen/section_spacing"
        android:paddingBottom="@dimen/section_spacing_large">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/parent_approvals_intro"
            android:textAppearance="@style/TextAppearance.HOME_App.Body" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/stack_spacing_small"
            android:text="@string/helper_approvals_chore"
            android:textAppearance="@style/TextAppearance.HOME_App.Supporting" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_spacing"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/parent_approvals_chore_section"
                android:textAppearance="@style/TextAppearance.HOME_App.CardTitle" />

            <TextView
                android:id="@+id/text_chore_pending_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_attention"
                android:paddingHorizontal="@dimen/chip_horizontal_padding"
                android:paddingVertical="@dimen/chip_vertical_padding"
                android:text="@string/label_pending_two"
                android:textAppearance="@style/TextAppearance.HOME_App.Badge"
                android:textColor="@color/status_attention_text" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_chore_requests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/text_chore_empty_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/stack_spacing"
            android:text="@string/parent_approvals_chore_empty"
            android:textAppearance="@style/TextAppearance.HOME_App.Supporting"
            android:visibility="gone" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_spacing"
            android:text="@string/helper_approvals_reward"
            android:textAppearance="@style/TextAppearance.HOME_App.Supporting" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/stack_spacing"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/parent_approvals_reward_section"
                android:textAppearance="@style/TextAppearance.HOME_App.CardTitle" />

            <TextView
                android:id="@+id/text_reward_pending_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_attention"
                android:paddingHorizontal="@dimen/chip_horizontal_padding"
                android:paddingVertical="@dimen/chip_vertical_padding"
                android:text="@string/label_pending_two"
                android:textAppearance="@style/TextAppearance.HOME_App.Badge"
                android:textColor="@color/status_attention_text" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_reward_requests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/text_reward_empty_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/stack_spacing"
            android:text="@string/parent_approvals_reward_empty"
            android:textAppearance="@style/TextAppearance.HOME_App.Supporting"
            android:visibility="gone" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_approvals_empty"
            style="@style/Widget.HOME_App.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_spacing"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/card_padding_large"
                android:text="@string/parent_approvals_empty"
                android:textAppearance="@style/TextAppearance.HOME_App.Body" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
