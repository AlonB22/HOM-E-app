<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/screen_horizontal_padding"
        android:paddingVertical="@dimen/section_spacing_large">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_parent"
            android:paddingHorizontal="@dimen/badge_horizontal_padding"
            android:paddingVertical="@dimen/badge_vertical_padding"
            android:text="@string/label_family_organizer"
            android:textAppearance="@style/TextAppearance.HOME_App.Badge"
            android:textColor="@color/parent_accent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_spacing"
            android:text="@string/app_name"
            android:textAlignment="center"
            android:textAppearance="@style/TextAppearance.HOME_App.HeroTitle" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/stack_spacing"
            android:text="@string/splash_message"
            android:textAlignment="center"
            android:textAppearance="@style/TextAppearance.HOME_App.Body" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.HOME_App.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_spacing_large">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/splash_card_title"
                    android:textAppearance="@style/TextAppearance.HOME_App.CardTitle" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/stack_spacing_small"
                    android:text="@string/splash_card_body"
                    android:textAppearance="@style/TextAppearance.HOME_App.Body" />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progress_splash"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/input_spacing"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/text_splash_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/stack_spacing_small"
                    android:textAppearance="@style/TextAppearance.HOME_App.Supporting"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_get_started"
            style="@style/Widget.HOME_App.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_spacing_large"
            android:text="@string/action_get_started" />
    </LinearLayout>
</ScrollView>
