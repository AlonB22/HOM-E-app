<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/screen_horizontal_padding"
        android:paddingTop="@dimen/section_spacing"
        android:paddingBottom="@dimen/section_spacing_large">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_parent"
            android:paddingHorizontal="@dimen/badge_horizontal_padding"
            android:paddingVertical="@dimen/badge_vertical_padding"
            android:text="@string/label_parent_view"
            android:textAppearance="@style/TextAppearance.HOME_App.Badge"
            android:textColor="@color/parent_accent" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/stack_spacing"
            android:text="@string/create_edit_chore_body"
            android:textAppearance="@style/TextAppearance.HOME_App.Body" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.HOME_App.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_spacing">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding_large">

                <TextView
                    android:id="@+id/text_chore_form_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/create_edit_chore_create_title"
                    android:textAppearance="@style/TextAppearance.HOME_App.CardTitle" />

                <TextView
                    android:id="@+id/text_chore_form_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/stack_spacing_small"
                    android:background="@drawable/bg_status_neutral"
                    android:paddingHorizontal="@dimen/chip_horizontal_padding"
                    android:paddingVertical="@dimen/chip_vertical_padding"
                    android:text="@string/create_edit_chore_create_title"
                    android:textAppearance="@style/TextAppearance.HOME_App.Badge"
                    android:textColor="@color/status_neutral_text" />

                <TextView
                    android:id="@+id/text_chore_form_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/stack_spacing"
                    android:text="@string/create_edit_chore_create_hint"
                    android:textAppearance="@style/TextAppearance.HOME_App.Supporting" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.HOME_App.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/stack_spacing">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding_large">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/input_layout_chore_title"
                    style="@style/Widget.HOME_App.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_chore_title">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_text_chore_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapSentences" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/input_layout_chore_description"
                    style="@style/Widget.HOME_App.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/input_spacing"
                    android:hint="@string/hint_short_description">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_text_chore_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapSentences|textMultiLine"
                        android:maxLines="3" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/input_layout_chore_child"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/input_spacing"
                    android:hint="@string/hint_assigned_child">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/auto_complete_chore_child"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:cursorVisible="false"
                        android:dropDownHeight="wrap_content"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:inputType="none"
                        android:paddingVertical="14dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/stack_spacing_xsmall"
                    android:text="@string/helper_assigned_child"
                    android:textAppearance="@style/TextAppearance.HOME_App.Supporting" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/input_layout_chore_points"
                    style="@style/Widget.HOME_App.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/input_spacing"
                    android:hint="@string/hint_points_value">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_text_chore_points"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/stack_spacing_xsmall"
                    android:text="@string/helper_chore_points"
                    android:textAppearance="@style/TextAppearance.HOME_App.Supporting" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_chore_preview"
            style="@style/Widget.HOME_App.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/stack_spacing">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding_large">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_demo_preview"
                    android:textAppearance="@style/TextAppearance.HOME_App.CardTitle" />

                <TextView
                    android:id="@+id/text_chore_preview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/stack_spacing_small"
                    android:text="@string/label_preview_pending"
                    android:textAppearance="@style/TextAppearance.HOME_App.Supporting" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_save_chore"
            style="@style/Widget.HOME_App.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_spacing"
            android:text="@string/action_save_chore" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_cancel_chore"
            style="@style/Widget.HOME_App.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/input_spacing"
            android:text="@string/action_back_to_chores" />
    </LinearLayout>
</ScrollView>
