<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/screen_horizontal_padding"
        android:paddingTop="@dimen/section_spacing"
        android:paddingBottom="@dimen/section_spacing_large">


        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.HOME_App.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_spacing">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding_large">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layoutDirection="ltr"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/text_chore_detail_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="@style/TextAppearance.HOME_App.ScreenTitle" />

                    <TextView
                        android:id="@+id/text_chore_detail_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:paddingHorizontal="@dimen/chip_horizontal_padding"
                        android:paddingVertical="@dimen/chip_vertical_padding"
                        android:textAppearance="@style/TextAppearance.HOME_App.Badge" />
                </LinearLayout>

                <TextView
                    android:id="@+id/text_chore_detail_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/stack_spacing"
                    android:textAppearance="@style/TextAppearance.HOME_App.Body" />

                <TextView
                    android:id="@+id/text_chore_detail_points"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/input_spacing"
                    android:gravity="end"
                    android:textAppearance="@style/TextAppearance.HOME_App.Badge"
                    android:textColor="@color/child_accent" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.HOME_App.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/stack_spacing">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding_large">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:text="@string/child_chore_detail_review_title"
                    android:textAppearance="@style/TextAppearance.HOME_App.CardTitle" />

                <TextView
                    android:id="@+id/text_chore_review_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/stack_spacing_small"
                    android:textAppearance="@style/TextAppearance.HOME_App.Supporting" />

                <TextView
                    android:id="@+id/text_chore_submitted_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/stack_spacing_small"
                    android:text="@string/child_chore_submitted_hint"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_submit_chore"
            style="@style/Widget.HOME_App.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_spacing"
            android:text="@string/action_submit_chore" />
    </LinearLayout>
</ScrollView>
